# Frontend Environment Configuration

# Public URL for deep-linked routes (email invitations)
PUBLIC_URL=/

# Backend API URL - Backend runs on port 3001
REACT_APP_API_URL=http://localhost:3001/api

# React App Name
REACT_APP_NAME=Material Dashboard 2 React

# Disable source map generation to prevent stylis-plugin-rtl warnings
GENERATE_SOURCEMAP=false
